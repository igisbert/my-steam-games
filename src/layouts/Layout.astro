---
import '@fontsource/ubuntu/300.css';
import '@fontsource/ubuntu/400.css';
import '@fontsource/ubuntu/500.css';
import '@fontsource/ubuntu/700.css';
import '@fontsource/cinzel-decorative/400.css';
import '@fontsource/cinzel-decorative/700.css';
import cinzel400 from '@fontsource/cinzel-decorative/400.css?url';
import cinzel700 from '@fontsource/cinzel-decorative/700.css?url';
import Noise from '@/components/Noise.astro';

interface Props {
  title?: string;
}

const { title = 'Portfolio de Iñaki' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href={cinzel400} as="style" />
    <link rel="preload" href={cinzel700} as="style" />
    <title>{title}</title>
  </head>
  <body>
    <Noise />
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/reset.css';
  @import '../styles/styles.css';
</style>
