---
interface Props {
  appid: number;
  name: string;
  playtime_forever: number;
  coverUrl: string;
}

const { appid, name, playtime_forever, coverUrl } = Astro.props;

const hours = playtime_forever > 0 ? Math.floor(playtime_forever / 60) : null;
const hoursText = hours !== null ? `${hours.toLocaleString('es-ES')}h` : 'Horas no disponibles';
const altText = `Portada de ${name}`;
---

<article class="game-card-completed" tabindex="0">
  <div class="game-card-completed__image-wrapper">
    <img
      class="game-card-completed__image"
      src={coverUrl}
      alt={altText}
      loading="lazy"
      width="300"
      height="450"
    />
  </div>
  <div class="game-card-completed__info">
    <h3 class="game-card-completed__name">{name}</h3>
    <span class="game-card-completed__hours">{hoursText}</span>
  </div>
</article>

<style>
  .game-card-completed {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow var(--transition),
                transform var(--transition);
  }

  .game-card-completed:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .game-card-completed__image-wrapper {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background-color: var(--color-muted);
  }

  .game-card-completed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-card-completed__info {
    padding: var(--space-2) var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .game-card-completed__name {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-card-completed__hours {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 400;
  }
</style>
