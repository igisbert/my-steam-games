---
interface Props {
  appid: number;
  name: string;
  playtime_forever: number;
  coverUrl: string;
  lastPlayed?: string | null;
}

const { appid, name, playtime_forever, coverUrl, lastPlayed } = Astro.props;

const hours = playtime_forever > 0 ? Math.floor(playtime_forever / 60) : null;
const hoursText =
  hours !== null ? `${hours.toLocaleString("es-ES")}h` : "Family Sharing";
const altText = `Portada de ${name}`;
---

<article class="game-card-completed" tabindex="0">
  <div class="game-card-completed__image-wrapper">
    <img
      class="game-card-completed__image"
      src={coverUrl}
      alt={altText}
      loading="lazy"
      width="300"
      height="450"
    />
  </div>
  <div class="game-card-completed__info">
    <h3 class="game-card-completed__name">{name}</h3>
    <div class="game-card-completed__meta">
      {
        hours !== null ? (
          <span class="game-card-completed__hours">{hoursText}</span>
        ) : (
          <span class="game-card-completed__pill">{hoursText}</span>
        )
      }
      {
        lastPlayed && (
          <span class="game-card-completed__last-played">{lastPlayed}</span>
        )
      }
    </div>
  </div>
</article>

<style>
  .game-card-completed {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border: 6px solid var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      box-shadow var(--transition),
      transform var(--transition);
    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 20%;
  }

  @keyframes reveal {
    from {
      opacity: 0.25;
      transform: translateY(20px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @supports (corner-shape: squircle) {
    .game-card-completed {
      border-radius: 1.5rem;
      corner-shape: squircle;
    }
  }

  .game-card-completed:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .game-card-completed__image-wrapper {
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .game-card-completed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
  }

  @supports (corner-shape: squircle) {
    .game-card-completed__image {
      border-radius: 1.1rem;
      corner-shape: squircle;
    }
  }

  .game-card-completed__info {
    padding: var(--space-2) 6px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-2);
  }

  .game-card-completed__name {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-card-completed__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: auto;
  }

  .game-card-completed__hours {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.03em;
    transition:
      transform var(--transition),
      text-shadow var(--transition);
  }

  .game-card-completed__pill {
    font-size: 0.7rem;
    color: var(--color-surface);
    font-weight: 600;
    padding: 0.1em 0.5em;
    border-radius: 999px;
    letter-spacing: 0.03em;
    background: var(--color-accent);
  }

  @media (hover: hover) {
    .game-card-completed:hover
      .game-card-completed__hours:not(.game-card-completed__pill) {
      transform: scale(1.25);
      text-shadow: 0 0 12px color-mix(in srgb, var(--color-accent), transparent);
    }
  }

  .game-card-completed__last-played {
    font-size: 0.65rem;
    color: var(--color-primary);
    opacity: 0.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-left: var(--space-2);
  }
</style>
