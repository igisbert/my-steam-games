---
interface Props {
  appid: number;
  name: string;
  playtime_forever: number;
  lastPlayed?: string | null;
}

const { appid, name, playtime_forever, lastPlayed } = Astro.props;

const hours = Math.floor(playtime_forever / 60);
const hoursText = `${hours.toLocaleString("es-ES")}h`;
const coverUrl = `https://cdn.cloudflare.steamstatic.com/steam/apps/${appid}/header.jpg`;
const altText = `Portada de ${name}`;
---

<article class="game-card-top" tabindex="0">
  <div class="game-card-top__image-wrapper">
    <img
      class="game-card-top__image"
      src={coverUrl}
      alt={altText}
      loading="lazy"
      width="460"
      height="215"
    />
  </div>
  <div class="game-card-top__info">
    <h3 class="game-card-top__name">{name}</h3>
    <div class="game-card-top__meta">
      <span class="game-card-top__hours">{hoursText}</span>
      {
        lastPlayed && (
          <span class="game-card-top__last-played">{lastPlayed}</span>
        )
      }
    </div>
  </div>
</article>

<style>
  .game-card-top {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      box-shadow var(--transition),
      transform var(--transition);
    animation: reveal linear both;
    animation-timeline: view();
    animation-range: entry 5% cover 20%;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @supports (corner-shape: squircle) {
    .game-card-top {
      border-radius: 2.5rem;
      corner-shape: squircle;
    }
  }

  .game-card-top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .game-card-top__image-wrapper {
    aspect-ratio: 460 / 215;
    overflow: hidden;
    background-color: var(--color-muted);
  }

  .game-card-top__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-card-top__info {
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-2);
  }

  .game-card-top__name {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-card-top__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: auto;
  }

  .game-card-top__hours {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.03em;
    transition:
      transform var(--transition),
      text-shadow var(--transition);
  }

  @media (hover: hover) {
    .game-card-top:hover .game-card-top__hours {
      transform: scale(1.25);
      text-shadow: 0 0 12px color-mix(in srgb, var(--color-accent), transparent);
    }
  }

  .game-card-top__last-played {
    font-size: var(--text-xs);
    color: var(--color-primary);
    opacity: 0.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-left: var(--space-2);
  }
</style>
