---
interface Props {
  appid: number;
  name: string;
  playtime_forever: number;
}

const { appid, name, playtime_forever } = Astro.props;

const hours = Math.floor(playtime_forever / 60);
const hoursText = `${hours.toLocaleString('es-ES')}h`;
const coverUrl = `https://cdn.cloudflare.steamstatic.com/steam/apps/${appid}/header.jpg`;
const altText = `Portada de ${name}`;
---

<article class="game-card-top" tabindex="0">
  <div class="game-card-top__image-wrapper">
    <img
      class="game-card-top__image"
      src={coverUrl}
      alt={altText}
      loading="lazy"
      width="460"
      height="215"
    />
  </div>
  <div class="game-card-top__info">
    <h3 class="game-card-top__name">{name}</h3>
    <span class="game-card-top__hours">{hoursText}</span>
  </div>
</article>

<style>
  .game-card-top {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow var(--transition),
                transform var(--transition);
  }

  .game-card-top:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .game-card-top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .game-card-top__image-wrapper {
    aspect-ratio: 460 / 215;
    overflow: hidden;
    background-color: var(--color-muted);
  }

  .game-card-top__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-card-top__info {
    padding: var(--space-3) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .game-card-top__name {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-card-top__hours {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 400;
  }
</style>
