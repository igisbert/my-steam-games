---
interface Props {
  profile: {
    avatar: string;
    level: number;
    totalHours: number;
    accountAgeYears: number | null;
  };
}

const { profile } = Astro.props;
---

<section class="hero">
  <div class="hero__avatar-wrapper">
    <img
      class="hero__avatar"
      src={profile.avatar}
      alt="Avatar de Steam"
      width="112"
      height="112"
    />
  </div>
  <div class="hero__hours">
    <span class="hero__hours-value"
      >{profile.totalHours.toLocaleString("es-ES")}</span
    >
  </div>
  <span class="hero__label"
    >horas jugadas en steam<br />durante <span class="hero__label-accent"
      >{profile.accountAgeYears ?? "N/A"}</span
    >{profile.accountAgeYears !== null ? " años" : ""}</span
  >
</section>

<style>
  .hero {
    text-align: center;
    padding: clamp(60px, 10vw, 100px) var(--space-5) clamp(80px, 12vw, 120px);
    animation: heroScroll linear both;
    animation-timeline: scroll(block);
    animation-range: 5rem 20rem;
  }

  @keyframes heroScroll {
    0% {
      transform: scale(1);
      filter: blur(0);
      opacity: 1;
    }
    100% {
      transform: scale(0.7) translateY(30px);
      filter: blur(4px);
      opacity: 0.3;
    }
  }

  .hero__avatar-wrapper {
    margin: 0 auto var(--space-5);
    width: 150px;
    aspect-ratio: 1;
    border-radius: 50%;
    margin-bottom: 3rem;
  }

  .hero__avatar {
    width: 100%;
    height: 100%;
    border-radius: 2.5rem;
    object-fit: cover;
    display: block;
    background-color: var(--color-bg);
    corner-shape: notch;
    transition: border-radius var(--transition);
    outline: 0.5rem solid var(--color-accent);
    outline-offset: 0.5rem;
    box-shadow: 0px 0px 20px 20px
      color-mix(
        in srgb,
        color-mix(in srgb, var(--color-accent), white 15%),
        transparent 75%
      );
  }

  .hero__avatar:hover {
    border-radius: 1.5rem;
  }

  .hero__hours {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.1em;
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .hero__hours-value {
    font-family: "Cinzel Decorative", serif;
    font-size: clamp(100px, 14vw, 160px);
    font-weight: 700;
    color: var(--color-accent);
    text-shadow:
      0 0 20px rgba(230, 175, 46, 0.6),
      0 0 60px rgba(230, 175, 46, 0.3),
      0 0 100px rgba(230, 175, 46, 0.15);
  }

  .hero__label {
    display: block;
    font-size: clamp(12px, 2vw, 16px);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-primary);
    opacity: 0.6;
  }

  .hero__label-accent {
    color: var(--color-accent);
    opacity: 1;
  }
</style>
