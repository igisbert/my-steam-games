---
interface Props {
  profile: {
    avatar: string;
    level: number;
    totalHours: number;
    accountAgeYears: number | null;
  };
}

const { profile } = Astro.props;
---

<section class="hero">
  <div class="hero__avatar-wrapper">
    <img class="hero__avatar" src={profile.avatar} alt="Avatar de Steam" width="112" height="112" />
  </div>
  <div class="hero__hours">
    <span class="hero__hours-value">{profile.totalHours.toLocaleString('es-ES')}</span>
  </div>
  <span class="hero__label">horas jugadas en steam</span>
  <div class="hero__meta">
    <span class="hero__meta-item">Nv. {profile.level}</span>
    <span class="hero__meta-sep">·</span>
    <span class="hero__meta-item">{profile.accountAgeYears ?? 'N/A'}{profile.accountAgeYears !== null ? ' años' : ''}</span>
  </div>
</section>

<style>
  .hero {
    text-align: center;
    padding: clamp(60px, 10vw, 100px) var(--space-5) clamp(80px, 12vw, 120px);
  }

  .hero__avatar-wrapper {
    margin: 0 auto var(--space-5);
    width: 112px;
    height: 112px;
    border-radius: 50%;
    padding: 3px;
    background: var(--color-accent);
    box-shadow: 0 0 30px rgba(230, 175, 46, 0.35);
  }

  .hero__avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background-color: var(--color-bg);
  }

  .hero__hours {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.1em;
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .hero__hours-value {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(64px, 14vw, 160px);
    font-weight: 700;
    color: var(--color-accent);
    text-shadow:
      0 0 20px rgba(230, 175, 46, 0.6),
      0 0 60px rgba(230, 175, 46, 0.3),
      0 0 100px rgba(230, 175, 46, 0.15);
  }

  .hero__label {
    display: block;
    font-size: clamp(12px, 2vw, 16px);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-primary);
    opacity: 0.4;
  }

  .hero__meta {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(230, 175, 46, 0.4);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-accent);
    box-shadow: 0 0 12px rgba(230, 175, 46, 0.15);
  }

  .hero__meta-sep {
    font-size: var(--text-xs);
  }
</style>
