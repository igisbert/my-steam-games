---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
  .tag {
    font-size: 0.55rem;
    color: var(--color-primary);
    opacity: 0.5;
    background: rgba(245, 237, 240, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    white-space: nowrap;
  }
</style>
