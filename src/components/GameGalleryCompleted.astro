---
import GameCardCompleted from "@/components/GameCardCompleted.astro";
import GalleryTitle from "@/components/GalleryTitle.astro";
import textIcon from "@/assets/icons/text.svg?raw";
import timeIcon from "@/assets/icons/time.svg?raw";

interface Game {
  appid: number;
  name: string;
  playtime_forever: number;
  coverUrl?: string;
  lastPlayed?: string | null;
  tags?: string[];
}

interface Props {
  title: string;
  games: Game[];
}

const { title, games } = Astro.props;
---

<section class="gallery">
  <div class="gallery__header">
    <GalleryTitle title={title} />
    <div class="gallery__sort">
      <button
        class="gallery__sort-btn gallery__sort-btn--active"
        data-sort="name"
        set:html={`${textIcon} Nombre`}
      />
      <button
        class="gallery__sort-btn"
        data-sort="hours"
        set:html={`${timeIcon} Horas`}
      />
    </div>
  </div>
  <div class="gallery__grid">
    {
      games.map((game) => (
        <GameCardCompleted
          appid={game.appid}
          name={game.name}
          playtime_forever={game.playtime_forever}
          coverUrl={
            game.coverUrl ||
            `https://cdn.cloudflare.steamstatic.com/steam/apps/${game.appid}/library_600x900.jpg`
          }
          lastPlayed={game.lastPlayed}
          tags={game.tags}
        />
      ))
    }
  </div>
</section>

<script>
  function initSort() {
    document.querySelectorAll(".gallery").forEach((section) => {
      const grid = section.querySelector(".gallery__grid");
      const buttons = section.querySelectorAll(".gallery__sort-btn");
      if (!grid || !buttons.length) return;

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) =>
            b.classList.remove("gallery__sort-btn--active"),
          );
          btn.classList.add("gallery__sort-btn--active");

          const sortKey = btn.getAttribute("data-sort");
          const cards = [...grid.children];
          cards.sort((a, b) => {
            const aName =
              a.querySelector(".game-card-completed__name")?.textContent || "";
            const bName =
              b.querySelector(".game-card-completed__name")?.textContent || "";
            const aHours =
              parseInt(
                a.querySelector(".game-card-completed__hours")?.textContent ||
                  "0",
              ) || 0;
            const bHours =
              parseInt(
                b.querySelector(".game-card-completed__hours")?.textContent ||
                  "0",
              ) || 0;

            if (sortKey === "name") return aName.localeCompare(bName);
            return bHours - aHours;
          });
          cards.forEach((card) => grid.appendChild(card));
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initSort);
  initSort();
</script>

<style>
  .gallery {
    padding: 0 var(--space-5) var(--space-6);
  }

  .gallery__header {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .gallery__sort {
    position: absolute;
    right: 0;
    bottom: 0;
    display: flex;
    gap: var(--space-2);
  }

  @media (width < 950px) {
    .gallery__sort {
      position: static;
      width: 100%;
      justify-content: flex-end;
    }
  }

  .gallery__sort-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: transparent;
    color: var(--color-primary);
    border: 1px solid rgba(245, 237, 240, 0.15);
    border-radius: var(--radius);
    padding: var(--space-1) var(--space-3);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      background var(--transition),
      color var(--transition),
      border-color var(--transition);
  }

  .gallery__sort-btn :global(svg) {
    width: 14px;
    height: 14px;
  }

  .gallery__sort-btn:hover {
    background: rgba(245, 237, 240, 0.05);
    border-color: rgba(245, 237, 240, 0.3);
  }

  .gallery__sort-btn--active {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .gallery__sort-btn--active:hover {
    background: var(--color-accent);
    opacity: 0.9;
  }

  .gallery__sort-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  @media (max-width: 480px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }
  }
</style>
