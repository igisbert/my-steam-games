---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<h2 class="gallery__title">{title}</h2>

<style>
  .gallery__title {
    margin: 0 0 0.5rem;
    font-family: "Cinzel Decorative", serif;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-accent);
    text-shadow: 0 0 20px rgba(230, 175, 46, 0.3);
    position: relative;
    display: inline-block;
    text-align: center;
  }

  .gallery__title::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: -10%;
    width: 120%;
    height: 4px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-accent),
      transparent
    );
    transform: rotate(-1.5deg);
    opacity: 0.6;
  }
</style>
